{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "apt": ["libzip-dev", "libpng-dev", "libjpeg-dev", "libfreetype6-dev"]
  },
  "php": {
    "extensions": ["gd", "zip", "exif", "bcmath", "pdo_mysql"]
  },
  "steps": {
    "build": {
      "commands": [
        "mkdir -p storage/framework/{sessions,views,cache,testing} storage/logs bootstrap/cache && chmod -R a+rw storage",
        "php artisan config:cache",
        "php artisan event:cache",
        "php artisan view:cache"
      ]
    }
  },
  "deploy": {
    "variables": {
      "RAILPACK_PHP_EXTENSIONS": "gd,zip,exif,bcmath"
    }
  }
}
